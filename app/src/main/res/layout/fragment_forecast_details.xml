<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/forecast_details_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".forecast.views.ForecastDetailsFragment">

    <Button
        android:id="@+id/forecast_details_start"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/forecast_details_start"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <pl.training.runkeeper.commons.views.ImageBox
        android:id="@+id/forecast_details_image_box"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:image="@drawable/first_image"
        app:text="Forecast data"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>